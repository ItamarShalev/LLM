{
    "workbench.colorCustomizations": {
        "activityBar.activeBackground": "#2f7c47",
        "activityBar.background": "#2f7c47",
        "activityBar.foreground": "#e7e7e7",
        "activityBar.inactiveForeground": "#e7e7e799",
        "activityBarBadge.background": "#422c74",
        "activityBarBadge.foreground": "#e7e7e7",
        "commandCenter.border": "#e7e7e799",
        "sash.hoverBorder": "#2f7c47",
        "statusBar.background": "#215732",
        "statusBar.foreground": "#e7e7e7",
        "statusBarItem.hoverBackground": "#2f7c47",
        "statusBarItem.remoteBackground": "#215732",
        "statusBarItem.remoteForeground": "#e7e7e7",
        "titleBar.activeBackground": "#215732",
        "titleBar.activeForeground": "#e7e7e7",
        "titleBar.inactiveBackground": "#21573299",
        "titleBar.inactiveForeground": "#e7e7e799"
    },
    "peacock.color": "#215732",
        // Use uv virtual env as default interpreter (Windows)
    "python.defaultInterpreterPath": "${workspaceFolder}\\.venv\\Scripts\\python.exe",

    // For Linux/MacOS use:
    // "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",

    // Make VSCode/Pylance resolve your modules (e.g., src/)
    "python.analysis.extraPaths": [
        "${workspaceFolder}/src",
        "${workspaceFolder}"
    ],

    // Optional: Formatting and linting preferences
    "editor.formatOnSave": true,

    "[python]": {
        "editor.defaultFormatter": "ms-python.vscode-pylance"
    },

    // Ruff integration (if installed)
    "ruff.organizeImports": true,

    // Test discovery (pytest)
    "python.testing.pytestEnabled": true,
    "python.testing.pytestArgs": [
        "tests"
    ],

    // Ensure integrated terminal uses the same venv
    "terminal.integrated.env.windows": {
        "VIRTUAL_ENV": "${workspaceFolder}\\.venv",
        "PATH": "${workspaceFolder}\\.venv\\Scripts;${env:PATH}"
    }

    // Linux / MacOS equivalent:
    // "terminal.integrated.env.linux": {
    //     "VIRTUAL_ENV": "${workspaceFolder}/.venv",
    //     "PATH": "${workspaceFolder}/.venv/bin:${env:PATH}"
    // }
}
