# Copy this file to ".env" and fill in the two values below.
# These are the ONLY secrets you must provide. Never commit .env (it is gitignored).

# ---------------------------------------------------------------------------
# 1) HUGGING FACE TOKEN  (required)
# ---------------------------------------------------------------------------
# How to get it:
#   a. Create / log in to a free account at https://huggingface.co
#   b. Open https://huggingface.co/settings/tokens
#   c. Click "Create new token", type = Read, copy the value (starts with hf_...)
#   d. To use the OFFICIAL Llama repo, also open
#      https://huggingface.co/meta-llama/Llama-3.1-8B-Instruct and click
#      "Agree and access" to accept the license (one time, with the same account).
# Note: even WITHOUT this token the project is complete, because gated models
# fall back to a verified public mirror. The token only switches Llama to the
# official repo and raises download rate limits.
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ---------------------------------------------------------------------------
# 2) GPT KEY for Part 4 training-data generation  (required only for Part 4)
# ---------------------------------------------------------------------------
# The assignment calls this TOKEN_KEY; the standard name OPENAI_API_KEY also works.
TOKEN_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# OPENAI_API_KEY=        # alternative name, also accepted

# Default GPT model for data generation (overridable).
OPENAI_MODEL=gpt-5.4-mini
